# DO NOT COMMIT A REAL .env FILE

# --- Sports data ---
# ESPN is used keyless by default (no key required).

# SportSRC / API-Football V3 (api-sports.io)
# When set, the server switches from ESPN to api-football for match schedule + detail.
# Get a free key at https://dashboard.api-football.com/register (100 req/day free)
SPORTSRC_API_KEY=

# Optional Apify fallback chain for missing player fields
# Primary sequence in server:
# 1) APIFY_SOFASCORE_ACTOR (if set)
# 2) APIFY_TRANSFERMARKT_ACTOR (default below)
APIFY_TOKEN=
APIFY_SOFASCORE_ACTOR=azzouzana/sofascore-scraper-pro
APIFY_TRANSFERMARKT_ACTOR=data_xplorer/transfermarkt-api-scraper

# --- AI ---
# Free local option (recommended): run Ollama locally
# Example model: llama3.1:8b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=

# Google Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (supports free models like *:free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Groq (often low-cost/free-tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# xAI Grok
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Optional OpenAI fallback
OPENAI_API_KEY=

# Optional provider override for shared AI router.
# Values: ollama | deepseek | openrouter | groq | gemini | openai | xai | grok
AI_PROVIDER_PREFERENCE=

# --- Movies / Series (TMDB) ---
TMDB_API_KEY=
# Optional performance tuning (milliseconds)
# --- Redis (for distributed caching) ---
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
TMDB_TIMEOUT_MS=7000
TMDB_CACHE_TTL_MS=300000

# Historical open football data (football-data.co.uk via datasets/football-datasets)
FOOTBALL_DATA_TIMEOUT_MS=8000

# salimt transfermarkt open datalake fallback (team standings + logos)
SALIMT_DATA_TIMEOUT_MS=10000

# --- Server ---
APP_TZ=Europe/Brussels
PORT=18081

# CORS: restrict to your app domain in production (leave empty for dev)
# ALLOWED_ORIGIN=https://yourdomain.com
