# DO NOT COMMIT A REAL .env FILE

# --- Sports data ---
# ESPN is used keyless by default (no key required).

# Optional Apify fallback chain for missing player fields
# Primary sequence in server:
# 1) APIFY_SOFASCORE_ACTOR (if set)
# 2) APIFY_TRANSFERMARKT_ACTOR (default below)
APIFY_TOKEN=
APIFY_SOFASCORE_ACTOR=azzouzana/sofascore-scraper-pro
APIFY_TRANSFERMARKT_ACTOR=data_xplorer/transfermarkt-api-scraper

# --- AI ---
# Free local option (recommended): run Ollama locally
# Example model: llama3.1:8b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=

# OpenRouter (supports free models like *:free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Groq (often low-cost/free-tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional OpenAI fallback
OPENAI_API_KEY=

# --- Movies / Series (TMDB) ---
TMDB_API_KEY=

# --- Server ---
APP_TZ=Europe/Brussels
PORT=8080

# CORS: restrict to your app domain in production (leave empty for dev)
# ALLOWED_ORIGIN=https://yourdomain.com
