# ===================================================
# NEXORA — root .gitignore
# ===================================================

# Dependencies
node_modules/
**/node_modules/

# OS artefacts
.DS_Store
**/.DS_Store
Thumbs.db

# Environment — NEVER commit secrets
.env
.env.*
!.env.example

# Expo
.expo/
app/.expo/
app/dist/
app/web-build/
app/dist-android/
**/.expo-shared/

# React Native / Metro
**/.metro-health-check*
**/metro-cache/

# Android build output (native android/ at root)
android/local.properties
android/app/build/
android/build/
android/.gradle/
android/.cxx/
*.hprof

# Release keystores (debug keystore is ok to commit; release is NOT)
android/app/release.keystore
android/app/*.release.keystore
**/*.release.keystore
**/*.jks
# Note: android/app/debug.keystore is intentionally tracked

# iOS build output
ios/build/
ios/Pods/
ios/*.xcworkspace/
ios/DerivedData/

# App-level android/ios (Expo managed, regenerated by expo prebuild)
app/android/
app/ios/

# Gradle user home cache (CI uses gradle cache action)
.gradle/

# JavaScript bundles / source maps
*.jsbundle
*.map
!app/assets/**/*.map

# Build outputs / compiled artefacts
dist/
build/
out/

# APK / AAB release files
*.apk
*.aab
NEXORA-debug.apk
NEXORA-release.apk
nexora-v*.apk
**/nexora-v*.apk

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Test / coverage
coverage/
.nyc_output/

# IDE
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln

# Cloudflare Wrangler cache
.wrangler/

# Local JDK installed by tooling scripts
.local-jdk/
oracleJdk-*.jdk/

# Heap dumps
java_pid*.hprof
hs_err_pid*.log

# TypeScript build info
*.tsbuildinfo

# Root tsconfig is local-only (each workspace has its own)
tsconfig.json
check-assets.py
