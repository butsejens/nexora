{
  "name": "nexora-sports-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker + D1 sports API cache layer",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create nexora-sports",
    "d1:migrate:local": "wrangler d1 migrations apply SPORTS_DB --local",
    "d1:migrate:remote": "wrangler d1 migrations apply SPORTS_DB --remote",
    "kv:create": "wrangler kv:namespace create SPORTS_CACHE_KV",
    "kv:create:preview": "wrangler kv:namespace create SPORTS_CACHE_KV --preview"
  },
  "keywords": [
    "cloudflare",
    "worker",
    "d1",
    "sports",
    "cache"
  ],
  "author": "Nexora",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.77.0"
  }
}
