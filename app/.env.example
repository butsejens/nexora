# Base URL of your Nexora server
# iOS simulator: http://localhost:18081
# Android emulator: http://10.0.2.2:18081
# Physical device: http://<your-mac-lan-ip>:18081
# Cloud server example: https://your-nexora-api.onrender.com
EXPO_PUBLIC_API_BASE=https://nexora-api-8xxb.onrender.com

# Production recommendation:
# EXPO_PUBLIC_API_BASE=http://localhost:18081

# Optional dedicated sports API base (for example Cloudflare Workers).
# If set, all /api/sports/* requests go here first; all other API routes stay on EXPO_PUBLIC_API_BASE.
# Example: EXPO_PUBLIC_SPORTS_API_BASE=https://nexora.<your-account-or-domain>.workers.dev
# EXPO_PUBLIC_SPORTS_API_BASE=
# Production recommendation:
# EXPO_PUBLIC_SPORTS_API_BASE=https://nexora.dhgpfz2h8r.workers.dev

# Optional fallback list (comma-separated). App tries these automatically
# if EXPO_PUBLIC_API_BASE fails.
EXPO_PUBLIC_API_BASES=https://nexora-api-8xxb.onrender.com,http://localhost:18081

# Optional fallback list for sports API only (comma-separated).
# EXPO_PUBLIC_SPORTS_API_BASES=https://nexora.<your-account-or-domain>.workers.dev,https://your-nexora-api.onrender.com

# =====================================================
# AUTH (Firebase + OAuth)
# =====================================================
# Create a Firebase project and Web App, then paste values below.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OAuth client IDs for Google sign-in (from Firebase Auth > Sign-in method > Google)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# =====================================================
# PAYMENTS (RevenueCat)
# =====================================================
# RevenueCat public SDK keys (not secret server keys)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=nexora_premium

# =====================================================
# TMDB (The Movie Database)
# =====================================================
# Required for real movie, series, and trending data.
# Get a free API key at: https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=

# =====================================================
# ADS (Google Mobile Ads)
# =====================================================
# Required for native build plugin config and rewarded unlock flow
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=
