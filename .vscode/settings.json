{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/android/build": true,
    "**/android/app/build": true,
    "**/.gradle": true,
    "releases": true,
    ".venv": true,
    ".wrangler": true,
    "**/ios/Pods": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/android/build": true,
    "**/android/app/build": true,
    "releases": true,
    ".venv": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/android/build/**": true,
    "**/android/app/build/**": true,
    "**/.gradle/**": true,
    "**/.expo/**": true,
    "releases/**": true,
    ".venv/**": true,
    ".wrangler/**": true
  }
}
