{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Nexora App",
			"type": "shell",
			"command": "npm run app:tunnel",
			"args": [],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start Nexora Dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Expo LAN 8080 Stable",
			"type": "shell",
			"command": "npm",
			"args": [
				"-w",
				"app",
				"exec",
				"--",
				"expo",
				"start",
				"--lan",
				"--port",
				"8080",
				"--clear"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}